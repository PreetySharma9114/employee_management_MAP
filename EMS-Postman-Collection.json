{
  "info": {
    "name": "Employee Management System — Full API",
    "_postman_id": "ems-microservices-2026",
    "description": "Complete API collection for all EMS microservices.\n\nIMPORT STEPS:\n1. Import this file into Postman (File → Import)\n2. Import EMS-Environment.json as the Environment\n3. Select 'EMS Local' environment from the dropdown\n4. Run requests in order: Auth → Departments → Employees → Leave → Attendance\n\nBase URL: http://localhost:8080 (via NGINX API Gateway)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",      "value": "http://localhost:8080" },
    { "key": "token",         "value": "" },
    { "key": "user_id",       "value": "" },
    { "key": "employee_id",   "value": "" },
    { "key": "dept_id",       "value": "" },
    { "key": "leave_id",      "value": "" },
    { "key": "attendance_id", "value": "" }
  ],
  "item": [

    {
      "name": "Auth Service",
      "item": [
        {
          "name": "1. Register Admin User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@company.com\",\n  \"password\": \"password123\",\n  \"role\": \"admin\"\n}"
            },
            "description": "Register a new admin user. Role can be: admin | manager | employee"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var res = pm.response.json();",
                "pm.test('Register successful', () => pm.response.to.have.status(201));",
                "if (res.success) {",
                "  pm.collectionVariables.set('user_id', res.data.id);",
                "  console.log('user_id saved:', res.data.id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }]
        },
        {
          "name": "2. Register Employee User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@company.com\",\n  \"password\": \"pass1234\",\n  \"role\": \"employee\",\n  \"employeeId\": \"{{employee_id}}\"\n}"
            },
            "description": "Register a user linked to an employee record."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": ["if (!pm.collectionVariables.get('employee_id')) pm.collectionVariables.set('employee_id','1');"],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 201 or 409', () => { pm.expect(pm.response.code).to.be.oneOf([201,409]); });"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "3. Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@company.com\",\n  \"password\": \"password123\"\n}"
            },
            "description": "Login (dev OTP mode). OTP is published to ActiveMQ queue `/queue/auth.otp` and also returned in the response (so Postman can stay practical). Verify OTP to get JWT token."
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var res = pm.response.json();",
                "pm.test('Login successful (OTP sent)', () => pm.response.to.have.status(200));",
                "if (res.success && res.data.user) {",
                "  pm.collectionVariables.set('user_id', res.data.user.id);",
                "  if (res.data.otp) pm.collectionVariables.set('otp_code', res.data.otp);",
                "  console.log('otp_code saved (from login response)');",
                "}"
              ],
              "type": "text/javascript"
            }
          }]
        },
        {
          "name": "4. Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/verify-otp", "host": ["{{base_url}}"], "path": ["api","auth","verify-otp"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@company.com\",\n  \"otp\": \"{{otp_code}}\"\n}"
            },
            "description": "Verify OTP using `{email, otp}` (no otpRequestId). On success returns JWT token and auto-saves it to `{{token}}`."
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var res = pm.response.json();",
                "pm.test('OTP verified', () => pm.response.to.have.status(200));",
                "if (res.success && res.data.token) {",
                "  pm.collectionVariables.set('token', res.data.token);",
                "  console.log('JWT token saved.');",
                "}"
              ],
              "type": "text/javascript"
            }
          }]
        },
        {
          "name": "5. Verify Token",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/auth/verify", "host": ["{{base_url}}"], "path": ["api","auth","verify"] },
            "description": "Verify that the current JWT token is valid."
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Token valid', () => pm.response.to.have.status(200));"], "type": "text/javascript" } }]
        },
        {
          "name": "5. Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/users", "host": ["{{base_url}}"], "path": ["api","auth","users"] },
            "description": "List all registered users."
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"], "type": "text/javascript" } }]
        },
        {
          "name": "6. Get User by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/users/{{user_id}}", "host": ["{{base_url}}"], "path": ["api","auth","users","{{user_id}}"] },
            "description": "Get a specific user by their ID."
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200 or 404', () => { pm.expect(pm.response.code).to.be.oneOf([200,404]); });"], "type": "text/javascript" } }]
        },
        {
          "name": "7. Delete User",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/users/{{user_id}}", "host": ["{{base_url}}"], "path": ["api","auth","users","{{user_id}}"] },
            "description": "Delete a user by ID."
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Deleted or Not Found', () => { pm.expect(pm.response.code).to.be.oneOf([200,404]); });"], "type": "text/javascript" } }]
        }
      ]
    },

    {
      "name": "Department Service",
      "item": [
        {
          "name": "1. Create Department — Engineering",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/departments", "host": ["{{base_url}}"], "path": ["api","departments"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Engineering\",\n  \"description\": \"Responsible for all software development and architecture\",\n  \"budget\": 1200000\n}"
            },
            "description": "Create a new department. name (2-100 chars), description (5-500 chars), budget (>=0) are required."
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var res = pm.response.json();",
                "pm.test('Dept created or exists', () => { pm.expect(pm.response.code).to.be.oneOf([201,409]); });",
                "if (res.success) {",
                "  pm.collectionVariables.set('dept_id', res.data.id);",
                "  console.log('dept_id saved:', res.data.id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }]
        },
        {
          "name": "2. Create Department — HR",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/departments", "host": ["{{base_url}}"], "path": ["api","departments"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Human Resources\",\n  \"description\": \"Handles recruitment, payroll and employee relations\",\n  \"managerId\": \"{{user_id}}\",\n  \"budget\": 450000\n}"
            },
            "description": "Create an HR department with a manager linked."
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Created or Exists', () => { pm.expect(pm.response.code).to.be.oneOf([201,409]); });"], "type": "text/javascript" } }]
        },
        {
          "name": "3. Get All Departments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/departments", "host": ["{{base_url}}"], "path": ["api","departments"] },
            "description": "List all departments."
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"], "type": "text/javascript" } }]
        },
        {
          "name": "4. Get Department by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/departments/{{dept_id}}", "host": ["{{base_url}}"], "path": ["api","departments","{{dept_id}}"] },
            "description": "Get a specific department by its ID."
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200 or 404', () => { pm.expect(pm.response.code).to.be.oneOf([200,404]); });"], "type": "text/javascript" } }]
        },
        {
          "name": "5. Update Department",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/departments/{{dept_id}}", "host": ["{{base_url}}"], "path": ["api","departments","{{dept_id}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"budget\": 1500000,\n  \"managerId\": \"{{user_id}}\"\n}"
            },
            "description": "Update department. At least 1 field is required. Updatable fields: name, description, managerId, budget."
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Updated or Not Found', () => { pm.expect(pm.response.code).to.be.oneOf([200,404]); });"], "type": "text/javascript" } }]
        },
        {
          "name": "6. Delete Department",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/departments/{{dept_id}}", "host": ["{{base_url}}"], "path": ["api","departments","{{dept_id}}"] },
            "description": "Delete a department by ID."
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Deleted or Not Found', () => { pm.expect(pm.response.code).to.be.oneOf([200,404]); });"], "type": "text/javascript" } }]
        }
      ]
    },

    {
      "name": "Employee Service",
      "item": [
        {
          "name": "1. Create Employee",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/employees", "host": ["{{base_url}}"], "path": ["api","employees"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john.doe@company.com\",\n  \"department\": \"Engineering\",\n  \"role\": \"Senior Engineer\",\n  \"salary\": 95000\n}"
            },
            "description": "Create a new employee. All fields required. salary must be >= 0."
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var res = pm.response.json();",
                "pm.test('Employee created', () => pm.response.to.have.status(201));",
                "if (res.success) {",
                "  pm.collectionVariables.set('employee_id', res.data.id);",
                "  console.log('employee_id saved:', res.data.id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }]
        },
        {
          "name": "2. Get All Employees",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/employees", "host": ["{{base_url}}"], "path": ["api","employees"] },
            "description": "Returns all employees."
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"], "type": "text/javascript" } }]
        },
        {
          "name": "3. Get Employee by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/employees/{{employee_id}}", "host": ["{{base_url}}"], "path": ["api","employees","{{employee_id}}"] },
            "description": "Get a specific employee by ID."
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200 or 404', () => { pm.expect(pm.response.code).to.be.oneOf([200,404]); });"], "type": "text/javascript" } }]
        },
        {
          "name": "4. Update Employee",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/employees/{{employee_id}}", "host": ["{{base_url}}"], "path": ["api","employees","{{employee_id}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"salary\": 105000,\n  \"role\": \"Lead Engineer\"\n}"
            },
            "description": "Update employee. All fields optional — send only what you want to change."
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Updated or Not Found', () => { pm.expect(pm.response.code).to.be.oneOf([200,404]); });"], "type": "text/javascript" } }]
        },
        {
          "name": "5. Calculate Salary (gRPC Payroll)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/employees/{{employee_id}}/salary", "host": ["{{base_url}}"], "path": ["api","employees","{{employee_id}}","salary"] },
            "description": "Calculates net salary by calling the internal Payroll gRPC service. Applies 10% tax deduction."
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Salary calculated', () => pm.response.to.have.status(200));",
                "var res = pm.response.json();",
                "if (res.success) {",
                "  console.log('Base:', res.data.baseSalary, '| Tax:', res.data.taxDeduction, '| Net:', res.data.finalSalary);",
                "}"
              ],
              "type": "text/javascript"
            }
          }]
        },
        {
          "name": "6. Delete Employee",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/employees/{{employee_id}}", "host": ["{{base_url}}"], "path": ["api","employees","{{employee_id}}"] },
            "description": "Delete employee. This also triggers ActiveMQ events that cascade-delete all leave requests and attendance records for this employee."
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Deleted or Not Found', () => { pm.expect(pm.response.code).to.be.oneOf([200,404]); });"], "type": "text/javascript" } }]
        }
      ]
    },

    {
      "name": "Leave Service",
      "item": [
        {
          "name": "1. Submit Annual Leave",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/leaves", "host": ["{{base_url}}"], "path": ["api","leaves"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeId\": \"{{employee_id}}\",\n  \"type\": \"annual\",\n  \"startDate\": \"2026-04-07\",\n  \"endDate\": \"2026-04-11\",\n  \"reason\": \"Family vacation trip abroad\"\n}"
            },
            "description": "Submit a leave request. type: annual | sick | casual | unpaid. Dates must be YYYY-MM-DD. reason min 5 chars."
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var res = pm.response.json();",
                "pm.test('Leave created', () => pm.response.to.have.status(201));",
                "if (res.success) {",
                "  pm.collectionVariables.set('leave_id', res.data.id);",
                "  console.log('leave_id saved:', res.data.id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }]
        },
        {
          "name": "2. Submit Sick Leave",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/leaves", "host": ["{{base_url}}"], "path": ["api","leaves"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeId\": \"{{employee_id}}\",\n  \"type\": \"sick\",\n  \"startDate\": \"2026-03-20\",\n  \"endDate\": \"2026-03-21\",\n  \"reason\": \"Doctor appointment and recovery rest\"\n}"
            },
            "description": "Submit a sick leave request."
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));"], "type": "text/javascript" } }]
        },
        {
          "name": "3. Get All Leave Requests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/leaves", "host": ["{{base_url}}"], "path": ["api","leaves"] },
            "description": "Get all leave requests (no filter)."
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"], "type": "text/javascript" } }]
        },
        {
          "name": "4. Get Leaves — Filter by Status (pending)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/leaves?status=pending",
              "host": ["{{base_url}}"],
              "path": ["api","leaves"],
              "query": [{ "key": "status", "value": "pending" }]
            },
            "description": "Filter leaves by status. Options: pending | approved | rejected"
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"], "type": "text/javascript" } }]
        },
        {
          "name": "5. Get Leaves — Filter by Type (annual)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/leaves?type=annual",
              "host": ["{{base_url}}"],
              "path": ["api","leaves"],
              "query": [{ "key": "type", "value": "annual" }]
            },
            "description": "Filter leaves by type. Options: annual | sick | casual | unpaid"
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"], "type": "text/javascript" } }]
        },
        {
          "name": "6. Get Leaves — Filter by Employee",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/leaves?employeeId={{employee_id}}",
              "host": ["{{base_url}}"],
              "path": ["api","leaves"],
              "query": [{ "key": "employeeId", "value": "{{employee_id}}" }]
            },
            "description": "Get all leave requests for employee ID 1."
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"], "type": "text/javascript" } }]
        },
        {
          "name": "7. Get Leave by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/leaves/{{leave_id}}", "host": ["{{base_url}}"], "path": ["api","leaves","{{leave_id}}"] },
            "description": "Get a specific leave request by ID."
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200 or 404', () => { pm.expect(pm.response.code).to.be.oneOf([200,404]); });"], "type": "text/javascript" } }]
        },
        {
          "name": "8. Approve Leave",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/leaves/{{leave_id}}/status", "host": ["{{base_url}}"], "path": ["api","leaves","{{leave_id}}","status"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"approved\",\n  \"reviewNote\": \"Approved by HR manager\"\n}"
            },
            "description": "Approve a leave request. status must be: approved | rejected | pending"
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Updated or Not Found', () => { pm.expect(pm.response.code).to.be.oneOf([200,404]); });"], "type": "text/javascript" } }]
        },
        {
          "name": "9. Reject Leave",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/leaves/{{leave_id}}/status", "host": ["{{base_url}}"], "path": ["api","leaves","{{leave_id}}","status"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"rejected\",\n  \"reviewNote\": \"Insufficient notice period, please reapply with 2 weeks notice\"\n}"
            },
            "description": "Reject a leave request with an optional note."
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Updated or Not Found', () => { pm.expect(pm.response.code).to.be.oneOf([200,404]); });"], "type": "text/javascript" } }]
        },
        {
          "name": "10. Get Employee Leave History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/employees/{{employee_id}}/leaves", "host": ["{{base_url}}"], "path": ["api","employees","{{employee_id}}","leaves"] },
            "description": "Get all leave requests submitted by a specific employee."
          },
